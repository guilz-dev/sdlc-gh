{
  "name": "example/harness-sample",
  "description": "Minimal PHP sample for sdlc-gh product CI",
  "type": "project",
  "require": {
    "php": "^8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "squizlabs/php_codesniffer": "^3.10"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "lint": "phpcs --standard=PSR12 src tests",
    "test": "phpunit"
  }
}
